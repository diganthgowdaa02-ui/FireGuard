# FireGuard — Environment Variables
# Copy this to .env.local for local dev, or set in Vercel dashboard

# Full URL to your ESP32's /api/sensors endpoint
# Example: http://192.168.1.105/api/sensors
# Leave empty to run in demo/mock mode
ESP32_URL=

# Optional: just the IP for display in the dashboard
ESP32_IP=192.168.1.105
